---
import { albumMeta } from '../data/album';
---

<div class="hero hero--art">
  <figure class="hero-art">
    <img
      class="hero-art-img"
      src="/media/artwork/hard-problem-art.jpg"
      alt={`${albumMeta.title} hero artwork`}
      width="3328"
      height="1248"
      fetchpriority="high"
    />
    <div class="hero-art-veil" aria-hidden="true"></div>
  </figure>

  <div class="hero-grain"></div>

  <h1 class="sr-only">{albumMeta.artist} — {albumMeta.title}</h1>

  <div class="hero-text">
    <div class="hero-eyebrow">{albumMeta.artist.toUpperCase()}</div>
    <div class="hero-title-main">{albumMeta.title}</div>
    <div class="hero-meta-line">
      <span>APRIL 2026</span>
      <span class="dot">·</span>
      <span>9 TRACKS · 10 TAKES</span>
      <span class="dot">·</span>
      <span>LISTEN BELOW</span>
    </div>
  </div>

  <div class="scroll-indicator">SCROLL ↓</div>
</div>

<style>
  .hero--art {
    min-height: 100vh;
    justify-content: flex-end;
    gap: 0;
    padding: 0 0 5rem;
    overflow: hidden;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hero-art {
    position: absolute;
    inset: 0;
    margin: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
    z-index: 0;
  }

  .hero-art-img {
    display: block;
    width: min(100%, calc((100vh - 6rem) * 2.667));
    max-width: 100%;
    height: auto;
    max-height: calc(100vh - 4rem);
    object-fit: contain;
    filter: saturate(1.05) contrast(1.02);
    opacity: 0;
    animation: heroArtIn 2s ease 0.1s forwards;
  }

  .hero-art-veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 75% 55% at 50% 40%, transparent 0%, transparent 55%, rgba(10, 10, 12, 0.55) 100%),
      linear-gradient(180deg, rgba(10, 10, 12, 0.1) 0%, transparent 20%, transparent 55%, rgba(10, 10, 12, 0.92) 100%);
  }

  @keyframes heroArtIn {
    from { opacity: 0; transform: scale(1.015); }
    to   { opacity: 1; transform: scale(1); }
  }

  .hero-text {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    padding: 0 2rem;
  }

  .hero-eyebrow {
    font-family: var(--mono);
    font-size: clamp(0.65rem, 1.2vw, 0.85rem);
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: var(--magenta);
    opacity: 0;
    animation: fadeUp 1.8s ease 0.6s forwards;
  }

  .hero-title-main {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2.8rem, 7.5vw, 6rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    color: var(--white);
    margin: 0.9rem 0 1.4rem;
    text-shadow:
      0 2px 24px rgba(10, 10, 12, 0.9),
      0 0 60px rgba(10, 10, 12, 0.6);
    opacity: 0;
    animation: fadeUp 1.8s ease 0.9s forwards;
  }

  .hero-meta-line {
    font-family: var(--mono);
    font-size: clamp(0.6rem, 1.05vw, 0.75rem);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(232, 131, 58, 0.82);
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 1.8s ease 1.2s forwards;
    text-shadow: 0 1px 12px rgba(10, 10, 12, 0.8);
  }

  .hero-meta-line .dot {
    color: rgba(107, 63, 160, 0.85);
  }

  .hero .scroll-indicator {
    animation-delay: 2s, 3.5s;
    z-index: 2;
  }
</style>
